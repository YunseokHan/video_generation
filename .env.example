# Hugging Face authentication/cache.
# Copy this file to .env, then fill values for your machine/account.
HF_TOKEN=
HF_CACHE=/NHNHOME/WORKSPACE/26moe001_D/hf-cache
HF_HOME=/NHNHOME/WORKSPACE/26moe001_D/hf-cache
HUGGINGFACE_HUB_CACHE=/NHNHOME/WORKSPACE/26moe001_D/hf-cache/hub
HF_HUB_CACHE=/NHNHOME/WORKSPACE/26moe001_D/hf-cache/hub
DIFFUSERS_CACHE=/NHNHOME/WORKSPACE/26moe001_D/hf-cache/hub

# Weights & Biases.
WANDB_API_KEY=
WANDB_PROJECT=sdxl-frame-generator
WANDB_ENTITY=
WANDB_MODE=offline
WANDB_DIR=/NHNHOME/WORKSPACE/26moe001_D/yunseok/video_generation/outputs/wandb

# Dataset location (per-server). OPENVID_ROOT overrides config openvid_root so
# the same configs run on any server by editing only this file. Leave
# OPENVID_CSV blank to default to <OPENVID_ROOT>/OpenVid.csv.
OPENVID_ROOT=/abs/path/to/OpenVid_extracted
OPENVID_CSV=

# Runtime hygiene.
TOKENIZERS_PARALLELISM=false
